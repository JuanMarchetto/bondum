{
  "expo": {
    "scheme": "bondum",
    "userInterfaceStyle": "automatic",
    "orientation": "portrait",
    "web": {
      "output": "static"
    },
    "name": "Bondum",
    "slug": "bondum-mobile",
    "android": {
      "package": "xyz.bondum.mobile"
    },
    "ios": {
      "bundleIdentifier": "xyz.bondum.mobile"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Bondum to access your camera to scan QR codes and earn rewards."
        }
      ]
    ]
  }
}
