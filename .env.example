# Solana RPC endpoint (Helius recommended for priority fee estimation + DAS API)
EXPO_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Server-side RPC (used by reward distribution server)
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Privy credentials
EXPO_PUBLIC_PRIVY_APP_ID=your-privy-app-id
EXPO_PUBLIC_PRIVY_CLIENT_ID=your-privy-client-id

# Reward API URL
EXPO_PUBLIC_REWARD_API_URL=https://api.bondum.xyz
